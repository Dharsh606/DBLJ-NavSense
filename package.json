{
  "name": "dblj-navsense",
  "version": "1.0.0",
  "description": "AI Navigation Assistant for Visually Impaired Users",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "export": "next export",
    "android:build": "npm run build && npm run export && npx cap sync && npx cap open android",
    "android:run": "npm run build && npm run export && npx cap sync && npx cap run android",
    "android:apk": "npm run build && npm run export && npx cap sync && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^5.7.0",
    "@capacitor/cli": "^5.7.0",
    "@capacitor/core": "^5.7.0",
    "@googlemaps/js-api-loader": "^1.16.2",
    "@googlemaps/react-wrapper": "^1.1.35",
    "@tensorflow-models/coco-ssd": "^2.2.2",
    "@tensorflow/tfjs": "^4.14.0",
    "@types/google.maps": "^3.58.1",
    "clsx": "^2.0.0",
    "common-tags": "^1.8.2",
    "framer-motion": "^10.16.16",
    "lucide-react": "^0.294.0",
    "next": "14.0.4",
    "next-pwa": "^5.6.0",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.0.4",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  },
  "overrides": {
    "workbox-build": {
      "ajv": "^8.12.0"
    }
  }
}
